# M.A.M.A. Core 环境变量配置示例
# 复制为 .env 后填入真实值

# ── 图片生成（二选一） ──────────────────────────────
OPENAI_API_KEY=sk-xxx                    # DALL-E 3
DASHSCOPE_API_KEY=sk-xxx                  # 通义万相

# ── 公众号发布（已认证服务号） ─────────────────────────
MAMA_WECHAT_APP_ID=wx_xxxxxx              # 公众号 AppID
MAMA_WECHAT_APP_SECRET=xxxxxxxx           # 公众号 AppSecret
MAMA_ACCOUNT_TYPE=personal                # personal（个人号） / service（服务号）

# ── DailyHotApi 热榜服务（可选） ──────────────────────
# 启动方式: cd services/dailyhot && bash start.sh
DAILYHOT_API_URL=http://localhost:6688

# ── 公众号文章数据导出（可选） ────────────────────────
MAMA_EXPORTER_URL=http://localhost:3000
